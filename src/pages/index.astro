        <a href="/serious" class="text-sm text-[var(--text-muted)] hover:text-white transition-colors w-fit">
          boring version
        </a>
      </div>
    </section>
    <section class="flex flex-col gap-12">
      <h2 class="text-3xl font-medium text-[var(--text-main)]">what I've been up to</h2>
      {rows.map((row) => (
        <div class="flex flex-col gap-6">
          <h3 class="text-xl font-medium text-[var(--text-muted)]">{row.heading}</h3>
          <div class="drag-row flex overflow-x-auto gap-6 pb-4 hide-scrollbar cursor-grab">
            {row.items.map((item) => (
