  }
</style>
<script>
  const demos = document.querySelectorAll<HTMLElement>('.arc-demo-shell.is-complex');
  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (!entry.isIntersecting) continue;
      const demo = entry.target as HTMLElement;
      const transcript = demo.querySelector<HTMLElement>('.arc-demo-transcript');
      demo.classList.add('is-playing');
      const followStage = (selector: string) => {
        const stage = demo.querySelector<HTMLElement>(selector);
        if (!transcript || !stage) return;
        const offset = stage.getBoundingClientRect().top - transcript.getBoundingClientRect().top + transcript.scrollTop - 48;
        transcript.scrollTo({ top: offset, behavior: 'smooth' });
      };
      window.setTimeout(() => followStage('.stage-8'), 4500);
      window.setTimeout(() => followStage('.stage-10'), 6200);
      window.setTimeout(() => followStage('.stage-12'), 7700);
      observer.unobserve(entry.target);
    }
  }, { threshold: 0.28 });
  demos.forEach((demo) => observer.observe(demo));
</script>